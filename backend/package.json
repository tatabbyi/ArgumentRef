{
  "name": "argumentref-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Audio ingestion backend for Argument Referee.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:remote-audio": "tsx scripts/streamAudioFile.ts"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
